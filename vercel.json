{
  "version": 2,
  "buildCommand": "echo 'static site, no build step'",
  "outputDirectory": "web_control_demo",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/web_control_demo/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/models/hand_landmarker.task",
      "destination": "https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/latest/hand_landmarker.task"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.onnx)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(.*\\.task)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
